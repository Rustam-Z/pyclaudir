# Required
TELEGRAM_BOT_TOKEN=
PYCLAUDIR_OWNER_ID=

# Optional
PYCLAUDIR_DATA_DIR=./data
PYCLAUDIR_MODEL=claude-opus-4-6
PYCLAUDIR_EFFORT=high
PYCLAUDIR_DEBOUNCE_MS=0
PYCLAUDIR_RATE_LIMIT_PER_MIN=20
CLAUDE_CODE_BIN=claude

# Project-specific system prompt overlay (optional — omit for system.md only)
# PYCLAUDIR_PROJECT_PROMPT=prompts/project.md

# Jira via mcp-atlassian (optional — leave blank to skip)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# GitLab via @zereight/mcp-gitlab (optional — leave blank to skip)
GITLAB_URL=
GITLAB_TOKEN=
