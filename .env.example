# [Required] Your Telegram bot token, from BotFather.
TELEGRAM_BOT_TOKEN=

# [Required] Your Telegram user ID (integer). Used to restrict bot access to just you. You can find it by sending a message to @userinfobot on Telegram.
PYCLAUDIR_OWNER_ID=

# [Required] Claude settings — no defaults, must be set.
PYCLAUDIR_MODEL=claude-opus-4-7
PYCLAUDIR_EFFORT=high

# [Default] Claude settings — these have working defaults, so only set
# them if you want to change them.
# CLAUDE_CODE_BIN=claude
# PYCLAUDIR_DATA_DIR=./data
# PYCLAUDIR_DEBOUNCE_MS=0
# PYCLAUDIR_RATE_LIMIT_PER_MIN=20

# [Default] Tool capability toggles — all OFF by default. Each flag
# unlocks a set of Claude Code built-in tools. See `docs/tools.md` for
# the per-tool list and what enabling each implies.
# PYCLAUDIR_ENABLE_SUBAGENTS=false   # Agent tool — token-heavy, off by default
# PYCLAUDIR_ENABLE_BASH=false        # Bash, PowerShell, Monitor — shell execution
# PYCLAUDIR_ENABLE_CODE=false        # Edit, Write, Read, NotebookEdit, Glob, Grep, LSP

# Settings below have working defaults. Uncomment only if you want to
# change them. All settings are read in pyclaudir/config.py.

# [Default] Stuck-process watcher — if Claude goes silent mid-turn, kill it and
# start it again.
# PYCLAUDIR_LIVENESS_TIMEOUT_SECONDS=300   # max silence in seconds
# PYCLAUDIR_LIVENESS_POLL_SECONDS=30       # how often the watcher checks

# [Default] Tool errors — stop a turn that keeps failing tool calls.
# PYCLAUDIR_TOOL_ERROR_MAX_COUNT=3         # how many errors before stopping
# PYCLAUDIR_TOOL_ERROR_WINDOW_SECONDS=30   # or stop if errors keep coming this long

# [Default] "Still on it…" notice — sent when a turn takes a while.
# PYCLAUDIR_PROGRESS_NOTIFY_SECONDS=60

# [Default] Crash handling — wait before restarting Claude after a crash. The wait
# doubles each time, up to the cap. If too many crashes happen in the
# time window, the bot exits and something outside (systemd, docker)
# is expected to restart it.
# PYCLAUDIR_CRASH_BACKOFF_BASE=2           # first wait, in seconds
# PYCLAUDIR_CRASH_BACKOFF_CAP=64           # longest wait, in seconds
# PYCLAUDIR_CRASH_LIMIT=10                 # too-many-crashes threshold
# PYCLAUDIR_CRASH_WINDOW_SECONDS=600       # the time window for the threshold

# [Default] When the daily self-reflection task runs (UTC cron).
# Default: midnight UTC every day.
# PYCLAUDIR_SELF_REFLECTION_CRON=0 0 * * *

# [Optional] Jira (optional — leave blank to turn off)
# JIRA_URL=
# JIRA_USERNAME=
# JIRA_API_TOKEN=

# [Optional] GitLab (optional — leave blank to turn off)
# GITLAB_URL=
# GITLAB_TOKEN=

# [Optional] GitHub (optional — leave blank to turn off)
# GITHUB_PERSONAL_ACCESS_TOKEN=
# GITHUB_HOST=         # only for GitHub Enterprise; leave blank for github.com
