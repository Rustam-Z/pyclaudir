# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# Project data (runtime)
data/
!data/memories/.gitkeep

# Env
.env
.env.local

# Project-specific prompt (not shipped with open-source pyclaudir)
prompts/project.md

# Local plugin config — operator copies plugins.json.example on setup,
# then customises. Not tracked so different deployments don't fight
# over the file.
plugins.json

# Local access policy — operator copies access.json.example on setup,
# then customises (DM policy, allowed users/chats). Lives at repo root
# alongside plugins.json so both operator-edited config files sit
# together; not tracked so deployments don't fight over the file.
access.json

# Editors
.vscode/
.idea/
.DS_Store

# Claude Code local settings
.claude/
